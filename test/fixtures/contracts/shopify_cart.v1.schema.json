{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["cart_id", "lines", "subtotal", "total_quantity", "discount_codes", "checkout_url"],
  "additionalProperties": true,
  "properties": {
    "cart_id": { "type": "string" },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["line_id", "variant_id", "title", "variant_title", "image_url", "quantity", "line_total"],
        "additionalProperties": true,
        "properties": {
          "line_id": { "type": "string" },
          "variant_id": { "type": "string" },
          "title": { "type": "string" },
          "variant_title": { "type": "string" },
          "image_url": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "line_total": { "$ref": "#/$defs/money" }
        }
      }
    },
    "subtotal": { "$ref": "#/$defs/money" },
    "total_quantity": { "type": "integer" },
    "discount_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "applicable"],
        "additionalProperties": true,
        "properties": {
          "code": { "type": "string" },
          "applicable": { "type": "boolean" }
        }
      }
    },
    "checkout_url": { "type": "string" }
  },
  "$defs": {
    "money": {
      "$comment": "Duplicated across vendored schema files intentionally: no cross-file $ref so each file stays self-contained until the hub Task 10 export replaces them.",
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "string" },
        "currency": { "type": "string" }
      }
    }
  }
}
