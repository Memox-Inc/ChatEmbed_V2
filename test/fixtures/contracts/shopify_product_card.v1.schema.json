{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["product_id", "handle", "title", "image_url", "url", "price", "variants", "selected_variant_id", "available", "compare_at_price", "badge"],
  "additionalProperties": true,
  "properties": {
    "product_id": { "type": "string" },
    "handle": { "type": "string" },
    "title": { "type": "string" },
    "image_url": { "type": "string" },
    "url": { "type": "string" },
    "price": { "$ref": "#/$defs/money" },
    "compare_at_price": { "oneOf": [{ "$ref": "#/$defs/money" }, { "type": "null" }] },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "available", "price"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "available": { "type": "boolean" },
          "price": { "$ref": "#/$defs/money" }
        }
      }
    },
    "selected_variant_id": { "type": "string" },
    "available": { "type": "boolean" },
    "badge": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
  },
  "$defs": {
    "money": {
      "$comment": "Duplicated across vendored schema files intentionally: no cross-file $ref so each file stays self-contained until the hub Task 10 export replaces them.",
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "string" },
        "currency": { "type": "string" }
      }
    }
  }
}
